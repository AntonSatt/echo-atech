# 46elks SMS bridge config — copy to sms.env (gitignored) and fill in:
#   cp areyoudead/sms.env.example areyoudead/sms.env
# Credentials: 46elks.com dashboard -> API username + API password

ELKS_USER=uXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ELKS_PASS=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Recipient(s), E.164, comma-separated for several. NOTE: 46elks trial
# accounts can only text the number verified at signup.
SMS_TO=+46701234567

# --- optional (defaults shown) ---
# SMS_FROM=AreYouDead        # sender name: alphanumeric, max 11 chars
# SMS_DRYRUN=yes             # validate against the API without sending (free)
# SMS_COOLDOWN_S=20          # min seconds between SMS per alert type
# MQTT_HOST=127.0.0.1        # broker (via: adb forward tcp:1883 tcp:1883)
# MQTT_PORT=1883
